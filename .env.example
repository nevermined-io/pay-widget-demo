# Nevermined — the agent owner's credentials
NVM_API_KEY=
NVM_PLAN_ID=
NVM_AGENT_ID=
# sandbox, live, or custom (custom uses NVM_BACKEND_URL, defaults to http://localhost:3001)
NVM_ENVIRONMENT=custom

# Anthropic — powers the agent's responses
ANTHROPIC_API_KEY=

# Guest checkout — your app's user identifier
EXTERNAL_ID=demo-user-001

# Server port
PORT=5555
